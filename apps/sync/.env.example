# Webflow — get these from app.webflow.com → Site Settings → Integrations
WEBFLOW_API_TOKEN=
WEBFLOW_COLLECTION_ID=

# Algolia — get these from dashboard.algolia.com → Settings → API Keys
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_INDEX_NAME=

# Algolia index name for federated search (POST /api/search-all)
ALGOLIA_SEARCH_ALL_INDEX=search_all

# Base URL of your Webflow site (no trailing slash) — used to build result URLs
SITE_URL=https://your-site.webflow.io

# A random secret string to protect the /api/sync and /api/search-all endpoints
# Generate one with: openssl rand -hex 32
SYNC_SECRET=
